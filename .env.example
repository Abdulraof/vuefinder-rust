# Local storage
LOCAL_STORAGE=./storage

# S3 / S3-compatible storage (Cloudflare R2, MinIO, etc.)
S3_BUCKET=my-bucket
S3_REGION=auto
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
# Leave empty for standard AWS S3, set for R2/MinIO/etc.
# Example for Cloudflare R2: https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
# Optional key prefix inside the bucket (leave empty for root)
S3_PREFIX=
